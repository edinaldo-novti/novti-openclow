# ============================================================
# OpenClow — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ---------- Geral ----------
NODE_ENV=development
TZ=America/Sao_Paulo
DOMAIN=clow.novti.com.br

# ---------- Openflow ----------
OPENFLOW_PORT=8080
OPENFLOW_PROTOCOL=http
OPENFLOW_DOMAIN=clow.novti.com.br
OPENFLOW_API_SECRET=CHANGE_ME_openflow_api_secret_key_here
OPENFLOW_JWT_SECRET=CHANGE_ME_jwt_secret_key_here
OPENFLOW_ALLOW_SIGNUP=true
OPENFLOW_ADMIN_PASSWORD=CHANGE_ME_admin_password
OPENCLOW_GATEWAY_TOKEN=CHANGE_ME_gateway_token_here


# ---------- Grafana ----------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_grafana_password
GF_SERVER_ROOT_URL=http://grafana.localhost

# ---------- Mongo Express ----------
ME_CONFIG_BASICAUTH_USERNAME=admin
ME_CONFIG_BASICAUTH_PASSWORD=CHANGE_ME_mongoexpress_password

# ---------- Traefik (Produção) ----------
TRAEFIK_ACME_EMAIL=admin@example.com
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=CHANGE_ME_traefik_password

# ---------- Coolify / CI-CD ----------
GHCR_IMAGE=ghcr.io/edinaldo-novti/novti-openclow
COOLIFY_WEBHOOK_URL=https://your-coolify-instance.com/api/v1/deploy
COOLIFY_TOKEN=CHANGE_ME_coolify_api_token

# ---------- Limites de Recursos (Produção) ----------
OPENFLOW_MEMORY_LIMIT=1g
OPENFLOW_CPU_LIMIT=1.0

